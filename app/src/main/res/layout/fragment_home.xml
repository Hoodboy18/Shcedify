<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <!-- Logo UNAM -->
    <ImageView
        android:id="@+id/iv_logo_unam"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/logos_blanco_unam"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:contentDescription="Logo UNAM"
        app:layout_constraintEnd_toStartOf="@id/iv_logo_fca"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.3"
        app:layout_constraintHorizontal_chainStyle="packed" />

    <!-- Logo FCA -->
    <ImageView
        android:id="@+id/iv_logo_fca"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/logos_blanco_fca"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:contentDescription="Logo FCA"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_logo_unam"
        app:layout_constraintTop_toTopOf="@id/iv_logo_unam"
        app:layout_constraintBottom_toBottomOf="@id/iv_logo_unam" />

    <TextView
        android:id="@+id/tv_welcome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="32dp"
        android:text="¡Bienvenido a SchedifyFCA!"
        android:textColor="@color/on_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_logo_unam" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="32dp"
        android:text="Tu horario inteligente está en camino. Próximamente podrás gestionar tus materias aquí."
        android:textColor="@color/divider"
        android:textSize="16sp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_welcome" />

</androidx.constraintlayout.widget.ConstraintLayout>