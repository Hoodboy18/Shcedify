<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Estilo principal para botones -->
    <style name="MainButton" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>

        <!-- Color de fondo -->
        <item name="backgroundTint">@color/button_background</item>

        <!-- Color de texto -->
        <item name="android:textColor">@color/button_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Estilo para textos generales -->
    <style name="MainText" parent="TextAppearance.Material3.BodyLarge">

        <!-- Color del texto -->
        <item name="android:textColor">#FFFFFF</item>

        <!-- Negrita -->
        <item name="android:textStyle">bold</item>

        <!-- Tamaño opcional -->
        <item name="android:textSize">16sp</item>
        <item name="android:textAlignment">center</item>
    </style>

    <!-- Estilo para campos de texto -->
    <style name="MainTextInput" parent="Widget.Material3.TextInputLayout.FilledBox">

        <!-- Fondo -->
        <item name="boxBackgroundColor">#FFFFFF</item>

        <!-- Color del hint -->
        <item name="hintTextColor">#000000</item>

    </style>

</resources>